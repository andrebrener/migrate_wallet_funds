# Alchemy API key (https://www.alchemy.com/). Required.
ALCHEMY_API_KEY=

# Maximum USD value any destination wallet is allowed to accumulate.
# The planner packs tokens into destinations respecting this cap.
MAX_USD_PER_WALLET=100000

# Minimum USD value for a token to be included in the plan.
# Balances below this are treated as dust and skipped.
MIN_USD_TO_TRANSFER=3

# How far (in percent) a destination is allowed to exceed the cap when an
# atomic token balance can't be split. Default 10 means up to 110% of the cap.
CAP_TOLERANCE_PCT=10
